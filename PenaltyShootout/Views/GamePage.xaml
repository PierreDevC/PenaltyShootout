<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PenaltyShootout.ViewModels"
             x:Class="PenaltyShootout.Views.GamePage"
             x:DataType="vm:GameViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid>

        <!-- Game canvas — fills entire screen -->
        <GraphicsView x:Name="GameCanvas"
                      InputTransparent="False"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill">
            <GraphicsView.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated" />
            </GraphicsView.GestureRecognizers>
        </GraphicsView>

        <!-- ═══ HUD Bar — dedicated score / round info section ═══ -->
        <Grid VerticalOptions="Start"
              HorizontalOptions="Fill"
              BackgroundColor="#E0000000"
              ColumnDefinitions="*,Auto,*,Auto">

            <Grid.Padding>
                <OnPlatform x:TypeArguments="Thickness">
                    <On Platform="iOS"     Value="16,48,8,12" />
                    <On Platform="Android" Value="16,10,8,10" />
                    <On Platform="Default" Value="16,10,8,10" />
                </OnPlatform>
            </Grid.Padding>

            <!-- Player score -->
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="0">
                <Label Text="YOU"
                       FontAttributes="Bold"
                       TextColor="#AAAAAA"
                       HorizontalOptions="Center">
                    <Label.FontSize>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="iOS,Android" Value="11" />
                            <On Platform="Default"     Value="13" />
                        </OnPlatform>
                    </Label.FontSize>
                </Label>
                <Label Text="{Binding PlayerScore}"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center">
                    <Label.FontSize>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="iOS,Android" Value="36" />
                            <On Platform="Default"     Value="42" />
                        </OnPlatform>
                    </Label.FontSize>
                </Label>
            </VerticalStackLayout>

            <!-- Round info — center -->
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                <Label Text="{Binding RoundText}"
                       FontAttributes="Bold"
                       TextColor="#FFD700"
                       HorizontalOptions="Center">
                    <Label.FontSize>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="iOS,Android" Value="12" />
                            <On Platform="Default"     Value="14" />
                        </OnPlatform>
                    </Label.FontSize>
                </Label>
                <Label Text="VS"
                       FontAttributes="Bold"
                       TextColor="#666666"
                       HorizontalOptions="Center">
                    <Label.FontSize>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="iOS,Android" Value="20" />
                            <On Platform="Default"     Value="26" />
                        </OnPlatform>
                    </Label.FontSize>
                </Label>
            </VerticalStackLayout>

            <!-- Keeper score -->
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="0">
                <Label Text="KEEPER"
                       FontAttributes="Bold"
                       TextColor="#AAAAAA"
                       HorizontalOptions="Center">
                    <Label.FontSize>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="iOS,Android" Value="11" />
                            <On Platform="Default"     Value="13" />
                        </OnPlatform>
                    </Label.FontSize>
                </Label>
                <Label Text="{Binding KeeperScore}"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center">
                    <Label.FontSize>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="iOS,Android" Value="36" />
                            <On Platform="Default"     Value="42" />
                        </OnPlatform>
                    </Label.FontSize>
                </Label>
            </VerticalStackLayout>

            <!-- Menu button — inside the HUD bar, far right -->
            <Button Grid.Column="3"
                    Text="✕"
                    Clicked="OnMenuButtonClicked"
                    WidthRequest="36"
                    HeightRequest="36"
                    CornerRadius="18"
                    FontSize="14"
                    FontAttributes="Bold"
                    BackgroundColor="#55FFFFFF"
                    TextColor="White"
                    Padding="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Margin="8,0,4,0">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding ShowDifficultySelector}"
                                 Value="True">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

        </Grid>

        <!-- Bottom separator line under HUD -->
        <BoxView HeightRequest="1"
                 Color="#33FFFFFF"
                 VerticalOptions="Start"
                 HorizontalOptions="Fill"
                 InputTransparent="True">
            <BoxView.Margin>
                <OnPlatform x:TypeArguments="Thickness">
                    <On Platform="iOS"     Value="0,100,0,0" />
                    <On Platform="Android" Value="0,62,0,0"  />
                    <On Platform="Default" Value="0,62,0,0"  />
                </OnPlatform>
            </BoxView.Margin>
        </BoxView>

        <!-- Swipe hint — shown only during Aiming phase when difficulty is selected -->
        <Label Text="Swipe to aim and shoot"
               FontSize="14"
               TextColor="#88FFFFFF"
               HorizontalOptions="Center"
               VerticalOptions="End"
               Margin="0,0,0,30"
               InputTransparent="True">
            <Label.Triggers>
                <DataTrigger TargetType="Label"
                             Binding="{Binding ShowDifficultySelector}"
                             Value="True">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
                <DataTrigger TargetType="Label"
                             Binding="{Binding CurrentPhase}"
                             Value="Shooting">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
                <DataTrigger TargetType="Label"
                             Binding="{Binding CurrentPhase}"
                             Value="KeeperDive">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
                <DataTrigger TargetType="Label"
                             Binding="{Binding CurrentPhase}"
                             Value="Result">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
                <DataTrigger TargetType="Label"
                             Binding="{Binding CurrentPhase}"
                             Value="GameOver">
                    <Setter Property="IsVisible" Value="False" />
                </DataTrigger>
            </Label.Triggers>
        </Label>

        <!-- Difficulty selector overlay -->
        <Grid IsVisible="{Binding ShowDifficultySelector}"
              BackgroundColor="#CC000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="20">
                <Label Text="⚽ PENALTY SHOOTOUT"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center">
                    <Label.FontSize>
                        <OnPlatform x:TypeArguments="x:Double">
                            <On Platform="iOS,Android" Value="24" />
                            <On Platform="Default"     Value="28" />
                        </OnPlatform>
                    </Label.FontSize>
                </Label>
                <Label Text="Choose Difficulty"
                       FontSize="16"
                       TextColor="#AAAAAA"
                       HorizontalOptions="Center" />

                <Button Text="EASY"
                        Command="{Binding SetDifficultyCommand}"
                        CommandParameter="Easy"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        WidthRequest="220"
                        HeightRequest="55"
                        CornerRadius="28" />

                <Button Text="MEDIUM"
                        Command="{Binding SetDifficultyCommand}"
                        CommandParameter="Medium"
                        BackgroundColor="#F57F17"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        WidthRequest="220"
                        HeightRequest="55"
                        CornerRadius="28" />

                <Button Text="HARD"
                        Command="{Binding SetDifficultyCommand}"
                        CommandParameter="Hard"
                        BackgroundColor="#C62828"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        WidthRequest="220"
                        HeightRequest="55"
                        CornerRadius="28" />
            </VerticalStackLayout>
        </Grid>

        <!-- Play Again button — shown only on GameOver -->
        <Button Text="PLAY AGAIN"
                Command="{Binding PlayAgainCommand}"
                IsVisible="{Binding ShowPlayAgain}"
                BackgroundColor="#FFD700"
                TextColor="#333333"
                FontSize="20"
                FontAttributes="Bold"
                WidthRequest="240"
                HeightRequest="60"
                CornerRadius="30"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,80" />

    </Grid>
</ContentPage>
